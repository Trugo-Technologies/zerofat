# ZeroFat WebAPIs environment variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

ASPNETCORE_ENVIRONMENT=Development

# Database (modules.json)
DatabaseOptions__Provider=postgresql
DatabaseOptions__ConnectionString="Host=localhost;Port=5432;Database=zerofatdb;Username=postgres;Password=your_password;"

# Hangfire → src/Host/ZeroFat.WebAPIs/Configurations/hangfire.json
#   HangfireSettings:Storage:StorageProvider / :ConnectionString
#   HangfireSettings:Credentials:User / :Password
HangfireSettings__Storage__StorageProvider=postgresql
HangfireSettings__Storage__ConnectionString="Host=localhost;Port=5432;Database=zerofatdb;Username=postgres;Password=your_password;"
HangfireSettings__Credentials__User=Admin
HangfireSettings__Credentials__Password=your_hangfire_dashboard_password

# JWT (security.json)
SecuritySettings__JwtSettings__Key=your_jwt_signing_key_min_32_chars

# Stripe → src/Host/ZeroFat.WebAPIs/Configurations/stripe.json
#   (+ stripe.Development.json for local Currency / SuccessUrlDomain / webhook secret)
#   StripeSettings:SecretKey / :Currency / :SuccessUrlDomain / :CheckoutCompletedSecretKey
StripeSettings__SecretKey=sk_test_your_stripe_secret_key
StripeSettings__Currency=AED
StripeSettings__SuccessUrlDomain=https://localhost:7000/api/clientPortal-module
StripeSettings__CheckoutCompletedSecretKey=whsec_your_webhook_secret

# Paymob (paymob.json)
PaymobSettings__Username=
PaymobSettings__Password=
PaymobSettings__ApiKey=
PaymobSettings__SecretKey=
PaymobSettings__PublicKey=

# SMS - Twilio (sms.json)
SMS__Twilio__FromPhoneNumber=
SMS__Twilio__AccountSid=
SMS__Twilio__MessagingServiceSid=
SMS__Twilio__AuthToken=

# SMS - Etisalat (sms.json)
SMS__Etisalat__Username=
SMS__Etisalat__Password=

# Storage - Amazon S3 (storage.json)
Storage__MasterEncryptionKey=
Storage__Amazon__AccessKeyID=
Storage__Amazon__SecretAccessKey=
